# Stage 1: Build — compile TypeScript to JavaScript
FROM registry.access.redhat.com/ubi9/nodejs-22 AS builder

WORKDIR /opt/app-root/src

# Install all dependencies (including devDependencies for tsc)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source and config needed for build
COPY tsconfig.json ./
COPY src/ src/

# Compile TypeScript → dist/
RUN npm run build

# Stage 2: Production — lean runtime image with only compiled output
FROM registry.access.redhat.com/ubi9/nodejs-22

WORKDIR /opt/app-root/src

# Copy package manifests and install production-only dependencies
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Copy compiled output from builder
COPY --from=builder /opt/app-root/src/dist/ dist/

# Copy examples directory (needed at runtime for evaluation)
COPY examples/ examples/

# OpenShift compatibility: group 0 permissions for arbitrary UID
USER 0
RUN chgrp -R 0 /opt/app-root && chmod -R g=u /opt/app-root
USER 1001

# CLI tool — ENTRYPOINT is the binary, CMD defaults to --help
ENTRYPOINT ["node", "dist/cli.js"]
CMD ["--help"]
