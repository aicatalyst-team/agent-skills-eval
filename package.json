{
  "name": "agent-skills-eval",
  "version": "0.1.0",
  "description": "SDK and CLI for evaluating agentskills.io-style skills.",
  "type": "module",
  "bin": {
    "agent-skills-eval": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./provider": {
      "import": "./dist/provider.js",
      "types": "./dist/provider.d.ts"
    },
    "./openai-compatible": {
      "import": "./dist/openai-compatible-provider.js",
      "types": "./dist/openai-compatible-provider.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"test/**/*.test.mjs\"",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agentskills",
    "skills",
    "evals",
    "llm",
    "benchmark"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2"
}
